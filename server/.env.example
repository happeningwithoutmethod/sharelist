# Listen address (bind) — inside Docker the app listens on all interfaces
HOST=0.0.0.0

# Public hostname (must resolve to this machine for Let's Encrypt)
HOSTNAME=sharelist.servehttp.com

# Email for Let's Encrypt expiry notices (required for production HTTPS)
ACME_EMAIL=you@example.com

# --- HTTP (app listens here; nginx terminates TLS on 443) ---
ENABLE_HTTP=true
PORT=3000
PUBLIC_HTTP_URL=http://sharelist.servehttp.com

# --- App-level HTTPS (leave false when using nginx + Let's Encrypt) ---
ENABLE_HTTPS=false
HTTPS_PORT=3443
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem
PUBLIC_HTTPS_URL=https://sharelist.servehttp.com

# WebSocket URL advertised to hosts/connectors (QR / share links)
PUBLIC_URL=wss://sharelist.servehttp.com

# Passkey for the admin relay dashboard at /relay/info
# Accepts cookie (login form), Bearer token, or Basic auth password.
RELAY_INFO_PASSKEY=change-me

# YouTube Data API v3 key (required for /api/music/search).
# Enable "YouTube Data API v3" on a Google Cloud project, create an API key,
# restrict it to that API (and optionally to this server's IPs).
# search.list uses the Search Queries quota (~100 calls/day by default).
# See docs/youtube_data_api.md
YOUTUBE_API_KEY=

# --- Docker ---
# Production (Let's Encrypt via nginx + certbot):
#   docker compose up -d --build
#   docker compose --profile certs run --rm certbot-init
#   docker compose restart nginx
# See docs/letsencrypt.md
